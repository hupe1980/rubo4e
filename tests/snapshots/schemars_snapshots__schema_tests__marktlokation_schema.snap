    "Lokationszuordnung": {
      "description": "Modell für die Abbildung der Referenz auf die Lokationsbündelstruktur. Diese gibt an welche Marktlokationen,\nMesslokationen, Netzlokationen, technische/steuerbaren Ressourcen an einer Lokation vorhanden sind.\n\n> **Note:** [Lokationszuordnung JSON Schema](https://json-schema.app/view/%23?url=https://raw.githubusercontent.com/BO4E/BO4E-Schemas/v202501.0.0/src/bo4e_schemas/bo/Lokationszuordnung.json)",
      "type": "object",
      "properties": {
        "_id": {
          "description": "Eine generische ID, die für eigene Zwecke genutzt werden kann.\nZ.B. könnten hier UUIDs aus einer Datenbank stehen oder URLs zu einem Backend-System.",
          "type": [
            "string",
            "null"
          ]
        },
        "_typ": {
          "description": "BO type identifier — always `BoTyp::Lokationszuordnung` for this struct.",
          "anyOf": [
            {
              "$ref": "#/$defs/BoTyp"
            },
            {
              "type": "null"
            }
          ]
        },
        "_version": {
          "description": "Version der BO-Struktur aka \"fachliche Versionierung\"",
          "type": [
            "string",
            "null"
          ]
        },
        "gueltigkeit": {
          "description": "Zeitraum der Gültigkeit",
          "anyOf": [
            {
              "$ref": "#/$defs/Zeitraum"
            },
            {
              "type": "null"
            }
          ]
        },
        "lokationsbuendelcode": {
          "description": "Code, der angibt wie die Lokationsbündelstruktur zusammengesetzt ist (zu finden unter \"Codeliste der Lokationsbündelstrukturen\" auf <https://www.edi-energy.de/index.php?id=38>)",
          "type": [
            "string",
            "null"
          ]
        },
        "marktlokationen": {
          "description": "Liste mit referenzierten Marktlokationen",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#"
          }
        },
        "messlokationen": {
          "description": "Liste mit referenzierten Messlokationen",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/Messlokation"
          }
        },
        "netzlokationen": {
          "description": "Liste mit referenzierten Netzlokationen",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/Netzlokation"
          }
        },
        "steuerbareRessourcen": {
          "description": "Liste mit referenzierten steuerbaren Ressourcen",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/SteuerbareRessource"
          }
        },
        "technischeRessourcen": {
          "description": "Liste mit referenzierten technischen Ressourcen",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/TechnischeRessource"
          }
        },
        "zuordnungstyp": {
          "description": "Verknüpfungsrichtung z.B. Malo-Melo",
          "type": [
            "string",
            "null"
          ]
        },
        "zusatzAttribute": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/ZusatzAttribut"
          }
        }
      },
      "additionalProperties": true
    },
    "MaloId": {
      "description": "Marktlokations-ID (MaLo-ID): 11-digit string validated by BDEW checksum.\n\nThe 11th digit is a check digit computed from the first ten digits using the\nBDEW alternating-weight algorithm.\n\n# Examples\n```\nuse rubo4e::identifiers::MaloId;\n\nlet id = MaloId::new(\"51238696780\").unwrap();\nassert_eq!(id.as_ref(), \"51238696780\");\n```",
      "type": "string"
    },
    "MarktpartnerId": {
      "description": "Marktpartner-ID (Rollencodenummer): 13-digit numeric string.\n\nNo checksum is applied; all 13 characters must be decimal digits `[0-9]`.",
      "type": "string"
    },
    "Marktrolle": {
      "description": "Diese Rollen kann ein Marktteilnehmer einnehmen.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "BTR",
            "BIKO",
            "BKV",
            "DP",
            "EIV",
            "ESA",
            "KN",
            "LF",
            "MGV",
            "MSB",
            "NB",
            "RB",
            "UENB"
          ]
        },
        {
          "description": "Unknown or future variant — produced when deserializing a value\nthat is not yet known to this version of the library.",
          "type": "string",
          "const": "UNKNOWN"
        }
      ]
    },
    "Marktteilnehmer": {
      "description": "Objekt zur Aufnahme der Information zu einem Marktteilnehmer\n\n> **Note:** [Marktteilnehmer JSON Schema](https://json-schema.app/view/%23?url=https://raw.githubusercontent.com/BO4E/BO4E-Schemas/v202501.0.0/src/bo4e_schemas/bo/Marktteilnehmer.json)",
      "type": "object",
      "properties": {
        "_id": {
          "description": "Eine generische ID, die für eigene Zwecke genutzt werden kann.\nZ.B. könnten hier UUIDs aus einer Datenbank stehen oder URLs zu einem Backend-System.",
          "type": [
            "string",
            "null"
          ]
        },
        "_typ": {
          "description": "BO type identifier — always `BoTyp::Marktteilnehmer` for this struct.",
          "anyOf": [
            {
              "$ref": "#/$defs/BoTyp"
            },
            {
              "type": "null"
            }
          ]
        },
        "_version": {
          "description": "Version der BO-Struktur aka \"fachliche Versionierung\"",
          "type": [
            "string",
            "null"
          ]
        },
        "geschaeftspartner": {
          "description": "Der zu diesem Marktteilnehmer gehörende Geschäftspartner",
          "anyOf": [
            {
              "$ref": "#/$defs/Geschaeftspartner"
            },
            {
              "type": "null"
            }
          ]
        },
        "makoadresse": {
          "description": "Die 1:1-Kommunikationsadresse des Marktteilnehmers. Diese wird in der Marktkommunikation verwendet. Konkret kann dies eine eMail-Adresse oder ein AS4-Endpunkt sein.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "marktrolle": {
          "description": "Gibt im Klartext die Bezeichnung der Marktrolle an",
          "anyOf": [
            {
              "$ref": "#/$defs/Marktrolle"
            },
            {
              "type": "null"
            }
          ]
        },
        "rollencodenummer": {
          "description": "Gibt die Codenummer der Marktrolle an",
          "anyOf": [
            {
              "$ref": "#/$defs/MarktpartnerId"
            },
            {
              "type": "null"
            }
          ]
        },
        "rollencodetyp": {
          "description": "Gibt den Typ des Codes an",
          "anyOf": [
            {
              "$ref": "#/$defs/Rollencodetyp"
            },
            {
              "type": "null"
            }
          ]
        },
        "sparte": {
          "description": "Sparte des Marktteilnehmers, z.B. Gas oder Strom",
          "anyOf": [
            {
              "$ref": "#/$defs/Sparte"
            },
            {
              "type": "null"
            }
          ]
        },
        "zusatzAttribute": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/ZusatzAttribut"
          }
        }
      },
      "additionalProperties": true
    },
    "MeloId": {
      "description": "Messlokations-ID (MeLo-ID): 33-character string.\n\nStructure (per BDEW specification):\n- **Positions 1–2**: ISO 3166-1 alpha-2 country code, uppercase (e.g. `\"DE\"`, `\"AT\"`)\n- **Positions 3–33**: alphanumeric body `[A-Za-z0-9]` (31 characters)\n\nNo checksum is applied.\n\n# Examples\n```\nuse rubo4e::identifiers::MeloId;\n\nlet id = MeloId::new(\"DE0000000000000000000000000000001\").unwrap();\nassert_eq!(id.as_ref(), \"DE0000000000000000000000000000001\");\n```",
      "type": "string"
    },
    "Menge": {
      "description": "Abbildung einer Menge mit Wert und Einheit.\n\n> **Note:** [Menge JSON Schema](https://json-schema.app/view/%23?url=https://raw.githubusercontent.com/BO4E/BO4E-Schemas/v202501.0.0/src/bo4e_schemas/com/Menge.json)",
      "type": "object",
      "properties": {
        "_id": {
          "description": "Eine generische ID, die für eigene Zwecke genutzt werden kann.\nZ.B. könnten hier UUIDs aus einer Datenbank stehen oder URLs zu einem Backend-System.",
          "type": [
            "string",
            "null"
          ]
        },
        "_typ": {
          "description": "COM type identifier for this struct.",
          "anyOf": [
            {
              "$ref": "#/$defs/ComTyp"
            },
            {
              "type": "null"
            }
          ]
        },
        "_version": {
          "description": "Version der COM-Struktur aka \"fachliche Versionierung\"",
          "type": [
            "string",
            "null"
          ]
        },
        "einheit": {
          "description": "Gibt die Einheit zum jeweiligen Wert an",
          "anyOf": [
            {
              "$ref": "#/$defs/Mengeneinheit"
            },
            {
              "type": "null"
            }
          ]
        },
        "wert": {
          "description": "Gibt den absoluten Wert der Menge an",
          "type": [
            "string",
            "number",
            "null"
          ],
          "pattern": "^-?\\d+(\\.\\d+)?([eE]\\d+)?$"
        },
        "zusatzAttribute": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/ZusatzAttribut"
          }
        }
      },
      "additionalProperties": true
    },
