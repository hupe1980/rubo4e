    "Geschaeftspartner": {
      "description": "Mit diesem Objekt können Geschäftspartner übertragen werden.\nSowohl Unternehmen, als auch Privatpersonen können Geschäftspartner sein.\nHinweis: \"Marktteilnehmer\" haben ein eigenes BO, welches sich von diesem BO ableitet.\nHier sollte daher keine Zuordnung zu Marktrollen erfolgen.\n\n> **Note:** [Geschaeftspartner JSON Schema](https://json-schema.app/view/%23?url=https://raw.githubusercontent.com/BO4E/BO4E-Schemas/v202501.0.0/src/bo4e_schemas/bo/Geschaeftspartner.json)",
      "type": "object",
      "properties": {
        "_id": {
          "description": "Eine generische ID, die für eigene Zwecke genutzt werden kann.\nZ.B. könnten hier UUIDs aus einer Datenbank stehen oder URLs zu einem Backend-System.",
          "type": [
            "string",
            "null"
          ]
        },
        "_typ": {
          "description": "BO type identifier — always `BoTyp::Geschaeftspartner` for this struct.",
          "anyOf": [
            {
              "$ref": "#/$defs/BoTyp"
            },
            {
              "type": "null"
            }
          ]
        },
        "_version": {
          "description": "Version der BO-Struktur aka \"fachliche Versionierung\"",
          "type": [
            "string",
            "null"
          ]
        },
        "adresse": {
          "description": "Adresse des Geschäftspartners",
          "anyOf": [
            {
              "$ref": "#/$defs/Adresse"
            },
            {
              "type": "null"
            }
          ]
        },
        "amtsgericht": {
          "description": "Amtsgericht bzw Handelsregistergericht, das die Handelsregisternummer herausgegeben hat",
          "type": [
            "string",
            "null"
          ]
        },
        "anrede": {
          "description": "Mögliche Anrede der Person",
          "anyOf": [
            {
              "$ref": "#/$defs/Anrede"
            },
            {
              "type": "null"
            }
          ]
        },
        "ansprechpartner": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/Person"
          }
        },
        "geschaeftspartnerrollen": {
          "description": "Rollen, die die Geschäftspartner inne haben (z.B. Interessent, Kunde)",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/Geschaeftspartnerrolle"
          }
        },
        "glaeubigerId": {
          "description": "Die Gläubiger-ID welche im Zahlungsverkehr verwendet wird; Z.B. \"DE 47116789\"",
          "type": [
            "string",
            "null"
          ]
        },
        "handelsregisternummer": {
          "description": "Handelsregisternummer des Geschäftspartners",
          "type": [
            "string",
            "null"
          ]
        },
        "individuelleAnrede": {
          "description": "Im Falle einer nicht standardisierten Anrede kann hier eine frei definierbare Anrede vorgegeben werden.\nBeispiel: \"Vereinsgemeinschaft\", \"Pfarrer\", \"Hochwürdigster Herr Abt\".",
          "type": [
            "string",
            "null"
          ]
        },
        "kontaktwege": {
          "description": "Kontaktwege des Geschäftspartners",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/Kontaktweg"
          }
        },
        "nachname": {
          "description": "Nachname (Familienname) der Person",
          "type": [
            "string",
            "null"
          ]
        },
        "organisationsname": {
          "description": "Name der Firma, wenn Gewerbe oder andere Organisation.",
          "type": [
            "string",
            "null"
          ]
        },
        "organisationstyp": {
          "description": "Kennzeichnung ob es sich um ein Gewerbe/Unternehmen, eine Privatperson oder eine andere Art von Organisation handelt.",
          "anyOf": [
            {
              "$ref": "#/$defs/Organisationstyp"
            },
            {
              "type": "null"
            }
          ]
        },
        "titel": {
          "description": "Möglicher Titel der Person",
          "anyOf": [
            {
              "$ref": "#/$defs/Titel"
            },
            {
              "type": "null"
            }
          ]
        },
        "umsatzsteuerId": {
          "description": "Die Steuer-ID des Geschäftspartners; Beispiel: \"DE 813281825\"",
          "type": [
            "string",
            "null"
          ]
        },
        "vorname": {
          "description": "Vorname der Person",
          "type": [
            "string",
            "null"
          ]
        },
        "website": {
          "description": "Internetseite des Marktpartners",
          "type": [
            "string",
            "null"
          ]
        },
        "zusatzAttribute": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/ZusatzAttribut"
          }
        }
      },
      "additionalProperties": true
    },
    "Geschaeftspartnerrolle": {
      "description": "Diese Rollen kann ein Geschäftspartner einnehmen.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "LIEFERANT",
            "DIENSTLEISTER",
            "KUNDE",
            "INTERESSENT",
