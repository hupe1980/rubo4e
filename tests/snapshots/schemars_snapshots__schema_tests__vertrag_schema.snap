expression: "schema_json::<Vertrag>()"
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vertrag",
  "description": "Modell für die Abbildung von Vertragsbeziehungen;\nDas Objekt dient dazu, alle Arten von Verträgen, die in der Energiewirtschaft Verwendung finden, abzubilden.\n\n> **Note:** [Vertrag JSON Schema](https://json-schema.app/view/%23?url=https://raw.githubusercontent.com/BO4E/BO4E-Schemas/v202501.0.0/src/bo4e_schemas/bo/Vertrag.json)",
  "type": "object",
  "properties": {
    "_id": {
      "description": "Eine generische ID, die für eigene Zwecke genutzt werden kann.\nZ.B. könnten hier UUIDs aus einer Datenbank stehen oder URLs zu einem Backend-System.",
      "type": [
        "string",
        "null"
      ]
    },
    "_typ": {
      "description": "BO type identifier — always `BoTyp::Vertrag` for this struct.",
      "anyOf": [
        {
          "$ref": "#/$defs/BoTyp"
        },
        {
          "type": "null"
        }
      ]
    },
    "_version": {
      "description": "Version der BO-Struktur aka \"fachliche Versionierung\"",
      "type": [
        "string",
        "null"
      ]
    },
    "beschreibung": {
      "description": "Beschreibung zum Vertrag",
      "type": [
        "string",
        "null"
      ]
    },
    "sparte": {
      "description": "Unterscheidungsmöglichkeiten für die Sparte",
      "anyOf": [
        {
          "$ref": "#/$defs/Sparte"
        },
        {
          "type": "null"
        }
      ]
    },
    "unterzeichnervp1": {
      "description": "Unterzeichner des Vertragspartners 1",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/Unterschrift"
      }
    },
    "unterzeichnervp2": {
      "description": "Unterzeichner des Vertragspartners 2",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/Unterschrift"
      }
    },
    "vertragsart": {
      "description": "Hier ist festgelegt, um welche Art von Vertrag es sich handelt.",
      "anyOf": [
        {
          "$ref": "#/$defs/Vertragsart"
        },
        {
          "type": "null"
        }
      ]
    },
    "vertragsbeginn": {
      "description": "Gibt an, wann der Vertrag beginnt (inklusiv)",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "vertragsende": {
      "description": "Gibt an, wann der Vertrag (voraussichtlich) endet oder beendet wurde (exklusiv)",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "vertragskonditionen": {
      "description": "Festlegungen zu Laufzeiten und Kündigungsfristen",
      "anyOf": [
        {
          "$ref": "#/$defs/Vertragskonditionen"
        },
        {
          "type": "null"
        }
      ]
    },
    "vertragsnummer": {
      "description": "Eine im Verwendungskontext eindeutige Nummer für den Vertrag",
      "type": [
        "string",
        "null"
      ]
    },
    "vertragspartner1": {
      "description": "Der \"erstgenannte\" Vertragspartner.\nIn der Regel der Aussteller des Vertrags.\nBeispiel: \"Vertrag zwischen Vertragspartner 1 ...\"",
      "anyOf": [
        {
          "$ref": "#/$defs/Geschaeftspartner"
        },
        {
          "type": "null"
        }
      ]
    },
    "vertragspartner2": {
      "description": "Der \"zweitgenannte\" Vertragspartner.\nIn der Regel der Empfänger des Vertrags.\nBeispiel \"Vertrag zwischen Vertragspartner 1 und Vertragspartner 2\".",
      "anyOf": [
        {
          "$ref": "#/$defs/Geschaeftspartner"
        },
        {
          "type": "null"
        }
      ]
    },
    "vertragsstatus": {
      "description": "Gibt den Status des Vertrags an",
      "anyOf": [
        {
          "$ref": "#/$defs/Vertragsstatus"
        },
        {
          "type": "null"
        }
      ]
    },
    "vertragsteile": {
      "description": "Der Vertragsteil wird dazu verwendet, eine vertragliche Leistung in Bezug zu einer Lokation\n(Markt- oder Messlokation) festzulegen.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/Vertragsteil"
      }
    },
    "zusatzAttribute": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/ZusatzAttribut"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "Adresse": {
      "description": "Contains an address that can be used for most purposes.\n\n> **Note:** [Adresse JSON Schema](https://json-schema.app/view/%23?url=https://raw.githubusercontent.com/BO4E/BO4E-Schemas/v202501.0.0/src/bo4e_schemas/com/Adresse.json)",
      "type": "object",
      "properties": {
        "_id": {
          "description": "Eine generische ID, die für eigene Zwecke genutzt werden kann.\nZ.B. könnten hier UUIDs aus einer Datenbank stehen oder URLs zu einem Backend-System.",
          "type": [
            "string",
            "null"
          ]
        },
        "_typ": {
          "description": "COM type identifier for this struct.",
          "anyOf": [
            {
              "$ref": "#/$defs/ComTyp"
            },
            {
              "type": "null"
            }
          ]
        },
        "_version": {
          "description": "Version der COM-Struktur aka \"fachliche Versionierung\"",
          "type": [
            "string",
            "null"
          ]
        },
        "adresszusatz": {
          "description": "Zusatzhinweis zum Auffinden der Adresse, z.B. \"3. Stock linke Wohnung\"",
          "type": [
            "string",
            "null"
          ]
        },
        "coErgaenzung": {
          "description": "Im Falle einer c/o-Adresse steht in diesem Attribut die Anrede. Z.B. \"c/o Veronica Hauptmieterin\"",
          "type": [
            "string",
            "null"
          ]
        },
        "hausnummer": {
          "description": "Hausnummer inkl. Zusatz; z.B. \"3\", \"4a\"",
          "type": [
            "string",
            "null"
          ]
        },
        "landescode": {
          "description": "Offizieller ISO-Landescode",
          "anyOf": [
            {
              "$ref": "#/$defs/Landescode"
            },
            {
              "type": "null"
            }
          ]
        },
        "ort": {
          "description": "Bezeichnung der Stadt; z.B. \"Hückelhoven\"",
          "type": [
            "string",
            "null"
          ]
        },
        "ortsteil": {
          "description": "Bezeichnung des Ortsteils; z.B. \"Mitte\"",
          "type": [
            "string",
            "null"
          ]
        },
        "postfach": {
          "description": "Im Falle einer Postfachadresse das Postfach; Damit werden Straße und Hausnummer nicht berücksichtigt",
          "type": [
            "string",
            "null"
          ]
        },
        "postleitzahl": {
          "description": "Die Postleitzahl; z.B: \"41836\"",
          "type": [
            "string",
            "null"
          ]
        },
        "strasse": {
          "description": "Bezeichnung der Straße; z.B. \"Weserstraße\"",
          "type": [
            "string",
            "null"
          ]
        },
        "zusatzAttribute": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/ZusatzAttribut"
          }
        }
      },
      "additionalProperties": true
    },
    "Anrede": {
      "description": "Übersicht möglicher Anreden, z.B. eines Geschäftspartners.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "HERR",
            "FRAU",
            "EHELEUTE",
            "FIRMA",
            "FAMILIE",
            "ERBENGEMEINSCHAFT",
            "GRUNDSTUECKSGEMEINSCHAFT"
          ]
        },
        {
          "description": "Unknown or future variant — produced when deserializing a value\nthat is not yet known to this version of the library.",
          "type": "string",
          "const": "UNKNOWN"
        }
      ]
    },
    "BoTyp": {
